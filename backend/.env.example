# GitHub App credentials — create a GitHub App at github.com/settings/apps
GITHUB_APP_ID=123456

# RSA private key generated when creating the GitHub App.
# In shell: export GITHUB_PRIVATE_KEY="$(cat /path/to/private-key.pem)"
# In .env files: paste key with literal \n between lines (auth.py normalises them).
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEowIBAAKCAQEA...\n-----END RSA PRIVATE KEY-----"

# Webhook secret — set identically in GitHub App settings → Webhook → Secret
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
